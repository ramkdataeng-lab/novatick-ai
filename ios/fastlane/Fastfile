default_platform(:ios)

platform :ios do

  desc "Build and push to TestFlight"
  lane :beta do

    # Set up App Store Connect API key (no 2FA needed)
    api_key = app_store_connect_api_key(
      key_id:      ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id:   ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    # Sync signing certs via Match (read-only on CI)
    match(
      type:           "appstore",
      readonly:       true,
      app_identifier: "com.ramkdataeng.novatick",
      api_key:        api_key
    )

    # Increment build number automatically
    increment_build_number(
      build_number: ENV["GITHUB_RUN_NUMBER"] || "1"
    )

    # Build the app  (XcodeGen produces .xcodeproj, not .xcworkspace)
    build_app(
      scheme:                      "NovaTick",
      project:                     "NovaTick.xcodeproj",
      configuration:               "Release",
      export_method:               "app-store",
      export_options: {
        provisioningProfiles: {
          "com.ramkdataeng.novatick" => ENV["PROVISIONING_PROFILE_SPECIFIER"]
        }
      }
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key:           api_key,
      skip_waiting_for_build_processing: true
    )
  end

end
