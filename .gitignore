# ── Python ────────────────────────────────────────────────────
.env
__pycache__/
*.pyc
trades.log

# ── Xcode / XcodeGen generated (do NOT commit these) ──────────
ios/*.xcodeproj/
ios/*.xcworkspace/
ios/build/
ios/DerivedData/

# ── CocoaPods (not used yet, but guard against accidental add) ──
ios/Pods/
ios/Podfile.lock

